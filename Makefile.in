# -*- Makefile -*- (for emacs)
#
# This Makefile is intended for compiling Herwig++ plugins
#
# This Makefile received very little testing, 
# any bug reports are very welcome!
#
# Location of include files
THEPEGINCLUDE  =
HERWIGINCLUDE  =
GSLINCLUDE     = 
FASTJETINCLUDE = 
HEPMCINCLUDE =
PYTHONINCLUDE = $(shell python-config --include)
# Messy hack, not guaranteed to work:
FASTJETPATH = $(shell fastjet-config --prefix)
PYTHONPATH = $(shell python-config --prefix)
LDFLAGS= -L$(FASTJETPATH)/lib -lfastjet $(shell rivet-config --ldflags --libs)
# -L$(PYTHONPATH)/lib $(shell python-config --ldflags --libs)
SHARED_FLAG = 
INCLUDE = $(THEPEGINCLUDE) $(HERWIGINCLUDE) $(GSLINCLUDE) $(FASTJETINCLUDE) $(HEPMCINCLUDE) $(PYTHONINCLUDE)
# C++ flags
CXX =
CXXFLAGS =

ALLCCFILES=$(shell echo *.cc)

default : Instantons.so

%.o : %.cc %.h
	$(CXX) -fPIC $(CPPFLAGS) $(INCLUDE) $(CXXFLAGS) -c -shared $< -o $@

Instantons.so : MEInstantonSimpleTest.o
	$(CXX) -fPIC $(CPPFLAGS) $(INCLUDE) $(CXXFLAGS) $(SHARED_FLAG) $(LDFLAGS) \
	$(FCLIBS) $^ -o $@


clean:
	rm -f $(ALLCCFILES:.cc=.o) \
	Instantons.so

install:
	cp *.so $(HERWIGINSTALL)/lib/Herwig

